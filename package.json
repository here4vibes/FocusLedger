{
  "name": "express-postgres-starter",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "npm run db:generate && node server.js",
    "dev": "npm run db:generate && node server.js",
    "build": "npm run lint && npm test && npm run db:generate && npm run migrate",
    "migrate": "node migrate.js",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "jest --forceExit --testTimeout=10000",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:visual": "playwright test --config=playwright.visual.config.js",
    "test:visual:update": "playwright test --config=playwright.visual.config.js --update-snapshots",
    "monitor:post-deploy": "node scripts/post-deploy-monitor.js",
    "smoke": "node scripts/smoke.js",
    "lint": "eslint --config eslint.config.mjs server.js routes/*.js middleware/*.js lib/*.js",
    "lint:fix": "eslint --config eslint.config.mjs --fix server.js routes/*.js middleware/*.js lib/*.js",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.0.0",
    "apn": "^2.2.0",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "imap": "^0.8.19",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "openai": "^4.77.0",
    "pg": "^8.11.3",
    "plaid": "latest",
    "prisma": "^5.22.0",
    "resend": "^6.12.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "typescript": "^6.0.3"
  }
}
