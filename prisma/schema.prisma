// FocusLedger -- Prisma schema
// Generated from migration audit (Task #1867066 Phase 1)
// Run: npx prisma db push (or prisma migrate dev for versioned migrations)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- Users & Auth ------------------------------------------------------------
model users {
  id                         Int                       @id @default(autoincrement())
  email                      String                    @unique
  name                       String?
  password_hash              String?
  google_id                  String?
  auth_method                String                    @default("password") // 'password'|'google'|'both'
  avatar_url                 String?
  timezone                   String?
  utm_source                 String?
  utm_medium                 String?
  utm_campaign               String?
  utm_content                String?
  utm_term                   String?
  signup_referrer            String?
  login_count                Int                       @default(0)
  last_login_at              DateTime?
  last_active_at             DateTime?
  admin_pro_override         Boolean                   @default(false)
  pro_granted_by             String? // 'stripe'|'admin'|null
  pro_granted_until          DateTime?
  autopilot_expires_at       DateTime?
  tandem_plan                String?
  tandem_expires_at          DateTime?
  tandem_trial_activated_at  DateTime?
  is_qa_user                 Boolean                   @default(false)
  values_banner_dismissed    Boolean                   @default(false)
  previous_checkin_summary   String?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @default(now())
  expenses                   expense[]
  values                     user_value[]
  subscriptions              app_subscription[]        @relation("UserSubscriptions")
  budgets                    budget[]
  nudges                     nudge[]
  insurance_policies         insurance_policy[]
  documents                  document[]
  password_reset_tokens      password_reset_tokens[]
  account_deletion_tokens    account_deletion_tokens[]
  push_tokens                push_tokens[]
  notification_send_logs     notification_send_log[]
  analytics_events           analytics_event[]
  daily_plans                buddy_daily_plans[]
  engagement                 buddy_engagement?         @relation(fields: [buddy_engagementId], references: [id])
  conversations              buddy_conversations[]
  checkin_modes              checkin_mode_preferences? @relation(fields: [checkin_mode_preferencesId], references: [id])
  demo_sessions              buddy_demo_sessions[]
  linked_emails              linked_email[]
  email_stashes              email_tasks_stash[]
  followup_prefs             user_followup_pref[]
  followup_logs              followup_email_log[]
  customer_emails            customer_email[]
  contact_submissions        contact_submission[]
  time_blocks                time_block[]
  work_hour_blocks           work_hour_block[]
  email_connections          email_connection[]
  routines                   routine[]
  routine_nudge_prefs        routine_nudge_prefs?      @relation(fields: [routine_nudge_prefsId], references: [id])
  detected_patterns          detected_patterns[]
  routineSuggestion          routine_suggestions?      @relation(fields: [routine_suggestionsId], references: [id])
  focusSessions              focus_session[]
  focus_prefs                user_focus_prefs?         @relation(fields: [user_focus_prefsId], references: [id])
  time_estimations           time_estimation[]
  weekly_stats               weekly_stats[]
  insight_unlocks            insight_unlock[]
  plaid_items                plaid_item[]
  plaid_accounts             plaid_account[]
  plaid_transactions         plaid_transaction[]
  bill_preferences           bill_preferences[]
  ideas                      idea[]
  journal_entries            journal_entry[]
  subscriptions_stripe       app_subscription[]        @relation("StripeSubscriptions")
  adhd_tax_leads             adhd_tax_leads[]
  lead_magnet_emails         lead_magnet_email[]
  ios_waitlist               ios_waitlist[]
  buddy_engagementId         Int?
  checkin_mode_preferencesId Int?
  routine_nudge_prefsId      Int?
  routine_suggestionsId      Int?
  user_focus_prefsId         Int?
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String // SHA256 of raw token
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  users      users?    @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@index([user_id])
  @@index([token_hash])
}

model account_deletion_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  users      users?    @relation(fields: [usersId], references: [id])
  usersId    Int?
}

// -- Analytics & Tracking -----------------------------------------------------
model analytics_event {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  event_name  String
  event_data  Json     @default("{}")
  occurred_at DateTime @default(now())
  users       users?   @relation(fields: [usersId], references: [id])
  usersId     Int?

  @@map("analytics_events")
  @@index([user_id])
  @@index([occurred_at])
}

model adhd_tax_leads {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?
}

model visitor_sessions {
  id           String   @id @default(cuid())
  visitor_hash String   @unique
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_content  String?
  utm_term     String?
  landed_at    DateTime @default(now())
  last_seen_at DateTime @default(now())
}

model push_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@unique([user_id, token])
  @@index([user_id])
}

model notification_send_log {
  id               Int      @id @default(autoincrement())
  user_id          Int
  notification_key String
  send_date        DateTime
  created_at       DateTime @default(now())
  users            users?   @relation(fields: [usersId], references: [id])
  usersId          Int?

  @@unique([user_id, notification_key, send_date])
  @@index([user_id])
}

// -- Subscriptions & Billing --------------------------------------------------
model app_subscription {
  id                     Int       @id @default(autoincrement())
  user_id                Int
  plan                   String    @default("free") // 'free'|'pro'
  status                 String    @default("active") // 'active'|'cancelled'
  billing_cycle          String? // 'monthly'|'annual'
  stripe_subscription_id String?   @unique
  checkout_session_id    String?   @unique
  activated_at           DateTime?
  cancelled_at           DateTime?
  current_period_end     DateTime?
  updated_at             DateTime  @default(now())
  user                   users     @relation("UserSubscriptions", fields: [user_id], references: [id])
  stripeUser             users     @relation("StripeSubscriptions", fields: [user_id], references: [id], map: "app_subscription_stripe_user_id_fkey")

  @@index([user_id])
  @@index([status])
}

model promo_codes {
  id              Int                @id @default(autoincrement())
  code            String             @unique
  type            String? // 'days'|'percent'|'plan'
  value           Int? // e.g. 30 = 30 days free
  max_redemptions Int                @default(1)
  expires_at      DateTime?
  is_active       Boolean            @default(true)
  created_at      DateTime           @default(now())
  redemptions     promo_redemption[]
}

model promo_redemption {
  id            Int         @id @default(autoincrement())
  promo_code_id Int
  promo_code    promo_codes @relation(fields: [promo_code_id], references: [id], onDelete: Cascade)
  user_id       Int
  redeemed_at   DateTime    @default(now())

  @@map("promo_redemptions")
  @@unique([promo_code_id, user_id])
  @@index([user_id])
}

model budget {
  id            Int      @id @default(autoincrement())
  user_id       Int
  weekly_amount Decimal  @default(500.00)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
  users         users?   @relation(fields: [usersId], references: [id])
  usersId       Int?

  @@map("budgets")
  @@index([user_id])
}

// -- Tasks --------------------------------------------------------------------
model task {
  id                           Int                 @id @default(autoincrement())
  user_id                      Int
  title                        String
  description                  String?
  priority                     String              @default("medium") // 'low'|'medium'|'high'
  due_date                     DateTime?           @db.Date
  due_time                     DateTime?           @db.Time(6)
  is_completed                 Boolean             @default(false)
  completed_at                 DateTime?
  source                       String? // 'manual'|'onboarding'|'auto_bill'|'buddy_demo'|'recurring'
  recurring_task_id            Int?
  recurring_task               recurring_task?     @relation(fields: [recurring_task_id], references: [id])
  bill_merchant_key            String?
  bill_type                    String? // 'subscription'|'utility'|'insurance'|'rent'|'loan'
  merchant_hint                String?
  expected_amount              Decimal?
  auto_complete_note           String?
  auto_complete_transaction_id Int?
  notes                        String?
  duration_minutes             Int?
  duration_source              String? // 'manual'|'ai'
  value_id                     Int?
  is_household                 Boolean             @default(false)
  is_shared_with_partner       Boolean             @default(false)
  // Recurrence: stored directly on task (no recurring_task FK needed for simple patterns)
  recurrence_type              String?             @default("none") // 'none'|'daily'|'weekdays'|'weekly'|'monthly'
  recurrence_day               Int?                // weekly=day of week (0-6), monthly=day of month (1-31)
  created_at                   DateTime            @default(now())
  updated_at                   DateTime            @default(now())
  steps                        task_step[]
  substeps                     task_substep[]
  focus_sessions               focus_session[]
  routine_links                routine_task_link[]
  time_blocks                  time_block[]

  @@map("tasks")
  @@index([user_id, is_completed])
  @@index([user_id, due_date])
  @@index([recurring_task_id])
}

model task_step {
  id           Int       @id @default(autoincrement())
  task_id      Int
  task         task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  title        String
  is_completed Boolean   @default(false)
  sort_order   Int       @default(0)
  completed_at DateTime?
  created_at   DateTime  @default(now())

  @@map("task_steps")
  @@index([task_id])
}

model task_substep {
  id           Int      @id @default(autoincrement())
  task_id      Int
  task         task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  title        String
  is_completed Boolean  @default(false)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  @@map("task_substeps")
  @@index([task_id])
}

model recurring_task {
  id             Int       @id @default(autoincrement())
  user_id        Int
  title          String
  description    String?
  priority       String    @default("medium")
  frequency      String // 'daily'|'weekly'|'biweekly'|'monthly'
  next_due_date  DateTime
  end_date       DateTime?
  is_paused      Boolean   @default(false)
  value_id       Int?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())
  task_instances task[]

  @@map("recurring_tasks")
  @@index([user_id])
  @@index([next_due_date])
}

model time_estimation {
  id                Int       @id @default(autoincrement())
  task_id           Int
  user_id           Int
  estimated_minutes Int?
  actual_minutes    Int?
  calibration_score Decimal? // actual/estimated ratio
  estimated_at      DateTime  @default(now())
  completed_at      DateTime?
  users             users?    @relation(fields: [usersId], references: [id])
  usersId           Int?

  @@map("task_time_estimations")
  @@unique([task_id])
  @@index([user_id])
}

// -- Expenses & Money ---------------------------------------------------------
model categories {
  id                 Int                 @id @default(autoincrement())
  name               String
  color              String              @default("#6B6B80")
  icon               String              @default("")
  created_at         DateTime            @default(now())
  expenses           expense[]
  plaid_transactions plaid_transaction[]
}

model expense {
  id                   Int         @id @default(autoincrement())
  user_id              Int
  amount               Decimal
  description          String?
  category_id          Int?
  category             categories? @relation(fields: [category_id], references: [id])
  expense_date         DateTime
  source               String      @default("manual") // 'manual'|'plaid'
  plaid_transaction_id String?     @unique
  is_impulse           Boolean? // null=untriaged, true/false
  created_at           DateTime    @default(now())
  users                users?      @relation(fields: [usersId], references: [id])
  usersId              Int?

  @@map("expenses")
  @@index([user_id, expense_date])
  @@index([plaid_transaction_id])
}

model spending_session {
  id            Int       @id @default(autoincrement())
  user_id       Int
  started_at    DateTime  @default(now())
  ended_at      DateTime?
  planned_count Int       @default(0)
  impulse_count Int       @default(0)

  @@map("spending_sessions")
  @@index([user_id])
}

// -- Bank Sync (Plaid) ---------------------------------------------------------
model plaid_item {
  id               Int             @id @default(autoincrement())
  user_id          Int
  access_token     String // AES-256-GCM encrypted -- base64 string in Prisma
  item_id          String?
  institution_name String?
  institution_id   String?
  cursor           String? // Pagination cursor for transactionsSync
  last_synced_at   DateTime?
  created_at       DateTime        @default(now())
  plaid_accounts   plaid_account[]
  users            users?          @relation(fields: [usersId], references: [id])
  usersId          Int?

  @@index([user_id])
  @@map("plaid_items")
}

model plaid_account {
  id            Int                 @id @default(autoincrement())
  plaid_item_id Int
  plaid_item    plaid_item?         @relation(fields: [plaid_item_id], references: [id])
  user_id       Int
  account_id    String              @unique
  name          String?
  official_name String?
  type          String?
  subtype       String?
  mask          String?
  transactions  plaid_transaction[]
  users         users?              @relation(fields: [usersId], references: [id])
  usersId       Int?

  @@index([user_id])
  @@index([plaid_item_id])
  @@map("plaid_accounts")
}

model plaid_transaction {
  id               Int            @id @default(autoincrement())
  plaid_account_id Int
  account          plaid_account? @relation(fields: [plaid_account_id], references: [id])
  user_id          Int
  transaction_id   String         @unique
  amount           Decimal
  description      String?
  merchant_name    String?
  category_id      Int?
  category         categories?    @relation(fields: [category_id], references: [id])
  plaid_category   String?
  transaction_date DateTime?
  is_pending       Boolean        @default(false)
  is_confirmed     Boolean        @default(false)
  expense_id       Int?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now())
  users            users?         @relation(fields: [usersId], references: [id])
  usersId          Int?

  @@index([user_id, transaction_date])
  @@index([plaid_account_id])
  @@map("plaid_transactions")
}

model bill_preferences {
  id                    Int      @id @default(autoincrement())
  user_id               Int
  merchant_key          String
  merchant_display_name String?
  bill_type             String?
  is_disabled           Boolean  @default(false)
  updated_at            DateTime @default(now())
  users                 users?   @relation(fields: [usersId], references: [id])
  usersId               Int?

  @@unique([user_id, merchant_key])
  @@index([user_id])
}

// -- Values & Alignment --------------------------------------------------------
model user_value {
  id          Int                      @id @default(autoincrement())
  user_id     Int
  value_name  String
  maslow_tier String?
  icon        String?
  color       String?
  rank        Int?
  created_at  DateTime                 @default(now())
  alignments  values_alignment_score[]
  users       users?                   @relation(fields: [usersId], references: [id])
  usersId     Int?

  @@map("user_values")
  @@index([user_id])
}

model values_alignment_score {
  id         Int         @id @default(autoincrement())
  user_id    Int
  value_id   Int
  user_value user_value? @relation(fields: [value_id], references: [id])
  date       DateTime
  score      Int // 0-100
  created_at DateTime    @default(now())

  @@map("values_alignment_scores")
  @@unique([user_id, value_id, date])
  @@index([user_id, date])
}

// -- Journal & Mood ------------------------------------------------------------
model journal_entry {
  id         Int      @id @default(autoincrement())
  user_id    Int
  date       DateTime
  mood       Int? // 1-5
  content    String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("journal_entries")
  @@unique([user_id, date])
  @@index([user_id])
}

// -- Buddy / Accountabilibuddy ------------------------------------------------
model buddy_checkins {
  id         Int      @id @default(autoincrement())
  user_id    Int
  date       DateTime
  type       String // 'morning'|'evening'|'midday'
  mood       Int?
  response   Json?
  created_at DateTime @default(now())

  @@unique([user_id, date, type])
  @@index([user_id, date])
}

model buddy_daily_plans {
  id               Int      @id @default(autoincrement())
  user_id          Int
  date             DateTime
  mood             Int?
  plan_json        Json? // { slots: [{ task_id, reason, accepted }] }
  accepted         Boolean  @default(false)
  completion_count Int      @default(0)
  created_at       DateTime @default(now())
  users            users?   @relation(fields: [usersId], references: [id])
  usersId          Int?

  @@unique([user_id, date])
  @@index([user_id])
}

model buddy_patterns {
  id               Int       @id @default(autoincrement())
  user_id          Int
  pattern_type     String? // 'time'|'day'|'sequence'|'category'
  description      String?
  confidence_score Decimal?
  occurrence_count Int?
  is_active        Boolean   @default(true)
  last_seen_at     DateTime?
  surfaced_at      DateTime?
  dismissed_at     DateTime?
  created_at       DateTime  @default(now())

  @@index([user_id])
}

model buddy_midday_checkins {
  id         Int      @id @default(autoincrement())
  user_id    Int
  date       DateTime
  type       String // 'post_plan'|'afternoon_energy'|'pre_evening'
  response   Json?
  created_at DateTime @default(now())

  @@unique([user_id, date, type])
  @@index([user_id])
}

model buddy_engagement {
  id                          Int        @id @default(autoincrement())
  user_id                     Int        @unique
  consecutive_missed_checkins Int        @default(0)
  hook_restart_count          Int        @default(0)
  last_comeback_shown_at      DateTime?
  lapse_timestamps            DateTime[]
  push_at                     DateTime?
  day5_email_at               DateTime?
  day14_email_at              DateTime?
  updated_at                  DateTime   @default(now())
  users                       users[]
}

model buddy_conversations {
  id           Int      @id @default(autoincrement())
  user_id      Int
  session_date DateTime
  role         String // 'user'|'buddy'
  message      String
  turn         Int
  created_at   DateTime @default(now())
  users        users?   @relation(fields: [usersId], references: [id])
  usersId      Int?

  @@index([user_id, session_date])
}

model checkin_mode_preferences {
  id              Int     @id @default(autoincrement())
  user_id         Int     @unique
  preferred_mode  String? // 'form'|'conversation'
  manual_override Boolean @default(false)
  learned_after   Int     @default(0)
  users           users[]
}

model buddy_demo_sessions {
  id                   String    @id // UUID
  created_at           DateTime  @default(now())
  expires_at           DateTime?
  surfaced_values      Json?
  extracted_tasks      Json?
  conversation_summary String?
  claimed_user_id      Int?
  users                users?    @relation(fields: [usersId], references: [id])
  usersId              Int?
}

model buddy_demo_turns {
  id         Int      @id @default(autoincrement())
  session_id String
  role       String // 'user'|'buddy'
  message    String
  turn       Int
  created_at DateTime @default(now())

  @@index([session_id])
}

// -- Morning Launch ------------------------------------------------------------
model morning_streaks {
  id                  Int       @id @default(autoincrement())
  user_id             Int       @unique
  current_streak      Int       @default(0)
  longest_streak      Int       @default(0)
  last_completed_date DateTime?
  grace_day_available Boolean   @default(true)
  updated_at          DateTime  @default(now())
}

model morning_sessions {
  id              Int      @id @default(autoincrement())
  user_id         Int
  session_date    DateTime
  tasks_completed Int      @default(0)
  tasks_skipped   Int      @default(0)
  completed_at    DateTime @default(now())

  @@unique([user_id, session_date])
  @@index([user_id])
}

model morning_task_events {
  id           Int      @id @default(autoincrement())
  user_id      Int
  task_id      Int?
  event_type   String // 'completed'|'skipped'
  session_date DateTime
  created_at   DateTime @default(now())

  @@index([user_id, session_date])
  @@index([task_id])
}

// -- Routines ------------------------------------------------------------------
model routine_template {
  id        Int     @id @default(autoincrement())
  name      String
  category  String // 'morning'|'evening'|'weekly'|'productivity'|'movement'
  icon      String?
  tasks     Json? // Array of task objects
  is_active Boolean @default(true)

  @@map("routine_templates")
}

model routine {
  id                 Int                 @id @default(autoincrement())
  user_id            Int
  name               String
  time_of_day        String? // 'morning'|'evening'|'afternoon'|'any'
  day_of_week        Int? // 0-6 (Sunday-Saturday), null for daily
  task_ids           Int[]               @default([]) // Array of task IDs
  nudge_after_hour   Int? // Hour (0-23) to send nudge
  is_active          Boolean             @default(true)
  source_template_id Int?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @default(now())
  users              users?              @relation(fields: [usersId], references: [id])
  usersId            Int?
  routine_task_link  routine_task_link[]

  @@map("routines")
  @@index([user_id])
  @@index([is_active])
}

model routine_task_link {
  id         Int     @id @default(autoincrement())
  routine_id Int
  routine    routine @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  task_id    Int
  task       task    @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("routine_task_links")
  @@unique([routine_id, task_id])
  @@index([routine_id])
  @@index([task_id])
}

model routine_streaks {
  id                  Int      @id @default(autoincrement())
  routine_id          Int      @unique
  current_streak      Int      @default(0)
  best_streak         Int      @default(0)
  last_completed_date DateTime
}

model routine_nudge_prefs {
  id        Int     @id @default(autoincrement())
  user_id   Int     @unique
  enabled   Boolean @default(true)
  frequency String  @default("default") // 'default'|'less'|'more'
  users     users[]
}

model routine_nudge_event {
  id         Int      @id @default(autoincrement())
  user_id    Int
  routine_id Int?
  date       DateTime
  status     String? // 'sent'|'skipped'|'dismissed'
  skip_count Int      @default(0)
  created_at DateTime @default(now())

  @@map("routine_nudge_events")
  @@index([user_id, date])
  @@index([routine_id])
}

model detected_patterns {
  id                          Int                   @id @default(autoincrement())
  user_id                     Int
  pattern_type                String? // 'time'|'day'|'sequence'|'category'
  description                 String?
  confidence_score            Decimal?
  occurrence_count            Int?
  is_active                   Boolean               @default(true)
  task_ids                    String? // JSON-encoded array of Int task IDs: JSON.stringify([1,2,3])
  metadata                    Json?
  created_at                  DateTime              @default(now())
  suggestions                 routine_suggestions[] @relation("PatternSuggestions")
  routineSuggestionForPattern routine_suggestions[] @relation("RoutineSuggestionForPattern")
  users                       users?                @relation(fields: [usersId], references: [id])
  usersId                     Int?

  @@index([user_id])
}

model routine_suggestions {
  id                Int               @id @default(autoincrement())
  user_id           Int
  pattern_id        Int
  status            String            @default("pending") // 'pending'|'accepted'|'dismissed'
  presented_count   Int               @default(0)
  created_at        DateTime          @default(now())
  pattern           detected_patterns @relation("PatternSuggestions", fields: [pattern_id], references: [id])
  patternForRoutine detected_patterns @relation("RoutineSuggestionForPattern", fields: [pattern_id], references: [id], map: "routine_suggestions_pattern_for_routine_fkey")
  users             users[]

  @@index([user_id])
  @@index([pattern_id])
}

// -- Focus Mode ----------------------------------------------------------------
model focus_session {
  id                       Int       @id @default(autoincrement())
  task_id                  Int
  task                     task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user_id                  Int
  planned_duration_seconds Int?
  actual_duration_seconds  Int?
  completed                Boolean   @default(false)
  started_at               DateTime  @default(now())
  ended_at                 DateTime?
  users                    users?    @relation(fields: [usersId], references: [id])
  usersId                  Int?

  @@map("focus_sessions")
  @@index([user_id])
  @@index([task_id])
}

model user_focus_prefs {
  id                  Int     @id @default(autoincrement())
  user_id             Int     @unique
  body_double_enabled Boolean @default(false)
  ambient_style       String  @default("cafe") // 'cafe'|'library'|'rain'
  ambient_volume      Int     @default(50) // 0-100
  users               users[]
}

// -- Vault / Documents ---------------------------------------------------------
model document {
  id                    Int       @id @default(autoincrement())
  user_id               Int
  name                  String
  category              String?
  s3_url                String?
  file_size             Int?
  mime_type             String?
  uploaded_at           DateTime  @default(now())
  expiry_date           DateTime?
  metadata_json         Json?
  ai_extracted          Boolean   @default(false)
  extraction_status     String    @default("none") // 'none'|'pending'|'processing'|'done'|'failed'
  extraction_confidence Json?
  notes                 String?
  metadata_confirmed    Boolean   @default(false)
  users                 users?    @relation(fields: [usersId], references: [id])
  usersId               Int?

  @@map("documents")
  @@index([user_id])
  @@index([user_id, category])
}

model ai_extraction_usage {
  id         Int      @id @default(autoincrement())
  user_id    Int
  month      DateTime
  count      Int      @default(0)
  updated_at DateTime @default(now())

  @@unique([user_id, month])
  @@index([user_id])
}

// -- Notifications / Nudges ----------------------------------------------------
model nudge {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String // 'document_expiry'|'insurance_gap'|'score_drop'|'annual_review'
  title      String?
  body       String?
  action_url String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("nudges")
  @@index([user_id, is_read])
}

model nudge_preference {
  id      Int     @id @default(autoincrement())
  user_id Int
  type    String
  channel String // 'push'|'buddy'|'email'|'banner'
  enabled Boolean @default(true)

  @@map("nudge_preferences")
  @@unique([user_id, type, channel])
  @@index([user_id])
}

// -- Insurance -----------------------------------------------------------------
model insurance_policy {
  id           Int       @id @default(autoincrement())
  user_id      Int
  type         String? // 'auto'|'home'|'life'|'health'|'renters'|'other'
  provider     String?
  policy_num   String?
  coverage     String?
  premium      Decimal?
  expiry_date  DateTime?
  document_url String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  users        users?    @relation(fields: [usersId], references: [id])
  usersId      Int?

  @@map("insurance_policies")
  @@index([user_id])
}

model coverage_gaps_log {
  id          Int       @id @default(autoincrement())
  user_id     Int
  gap_type    String
  status      String    @default("open") // 'open'|'addressed'|'ignored'
  created_at  DateTime  @default(now())
  resolved_at DateTime?

  @@index([user_id])
}

// -- Ideas ---------------------------------------------------------------------
model idea {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("ideas")
  @@index([user_id])
}

// -- Time Blocks ---------------------------------------------------------------
model time_block {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String?
  date       DateTime
  start_time DateTime
  end_time   DateTime
  task_id    Int?
  task       task?    @relation(fields: [task_id], references: [id], onDelete: SetNull)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("time_blocks")
  @@index([user_id, date])
}

model work_hour_block {
  id          Int      @id @default(autoincrement())
  user_id     Int
  day_of_week Int // 0-6
  start_time  DateTime
  end_time    DateTime
  label       String?
  users       users?   @relation(fields: [usersId], references: [id])
  usersId     Int?

  @@map("work_hour_blocks")
  @@index([user_id])
}

// -- Email / OAuth -------------------------------------------------------------
model email_connection {
  id            Int       @id @default(autoincrement())
  user_id       Int
  email         String
  provider      String? // 'gmail'|'microsoft'|'yahoo'
  access_token  String?
  refresh_token String?
  expires_at    DateTime?
  created_at    DateTime  @default(now())
  users         users?    @relation(fields: [usersId], references: [id])
  usersId       Int?

  @@map("email_connections")
  @@unique([user_id, email])
  @@index([user_id])
}

model linked_email {
  id         Int      @id @default(autoincrement())
  user_id    Int
  email      String   @unique
  verified   Boolean  @default(false)
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("linked_emails")
  @@index([user_id])
}

model email_tasks_stash {
  id           Int      @id @default(autoincrement())
  user_id      Int
  sender_email String
  subject      String?
  body_preview String?
  expires_at   DateTime
  created_at   DateTime @default(now())
  users        users?   @relation(fields: [usersId], references: [id])
  usersId      Int?

  @@index([user_id])
  @@index([expires_at])
}

model followup_email_type {
  id           Int     @id @default(autoincrement())
  type         String  @unique // 'task_reminder'|'routine_streak'|'weekly_summary'|'follow_through'
  label        String?
  description  String?
  default_hour Int     @default(9)

  @@map("followup_email_types")
}

model user_followup_pref {
  id      Int     @id @default(autoincrement())
  user_id Int
  type    String
  enabled Boolean @default(true)
  hour    Int     @default(9)
  users   users?  @relation(fields: [usersId], references: [id])
  usersId Int?

  @@map("user_followup_prefs")
  @@unique([user_id, type])
  @@index([user_id])
}

model followup_email_log {
  id      Int      @id @default(autoincrement())
  user_id Int
  type    String
  ref     String?
  sent_at DateTime @default(now())
  users   users?   @relation(fields: [usersId], references: [id])
  usersId Int?

  @@unique([user_id, type, ref, sent_at])
  @@index([user_id, type, sent_at])
}

// -- Customer Inbox -------------------------------------------------------------
model customer_email {
  id              Int       @id @default(autoincrement())
  thread_id       String
  user_id         Int?
  direction       String // 'inbound'|'outbound'
  from_email      String?
  to_email        String?
  subject         String?
  body            String?
  resend_email_id String?   @unique
  read_at         DateTime?
  created_at      DateTime  @default(now())
  users           users?    @relation(fields: [usersId], references: [id])
  usersId         Int?

  @@map("customer_emails")
  @@index([thread_id])
  @@index([user_id])
}

// -- Contact / Support ---------------------------------------------------------
model contact_submission {
  id         Int      @id @default(autoincrement())
  name       String?
  email      String?
  message    String?
  category   String? // 'bug'|'account_issue'|'other'
  page_url   String?
  browser    String?
  status     String   @default("pending") // 'pending'|'resolved'
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?

  @@map("contact_submissions")
  @@index([status])
}

// -- News Feed -----------------------------------------------------------------
model news_feed {
  id           Int       @id @default(autoincrement())
  title        String
  url          String
  source       String?
  content      String?
  published_at DateTime?
  fetched_at   DateTime  @default(now())
}

// -- Weekly Stats --------------------------------------------------------------
model weekly_stats {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  week_start         DateTime
  tasks_completed    Int      @default(0)
  tasks_created      Int      @default(0)
  total_spend_cents  Int      @default(0)
  impulse_count      Int      @default(0)
  planned_count      Int      @default(0)
  evening_sessions   Int      @default(0)
  routines_completed Int      @default(0)
  streak_days        Int      @default(0)
  created_at         DateTime @default(now())
  users              users?   @relation(fields: [usersId], references: [id])
  usersId            Int?

  @@unique([user_id, week_start])
  @@index([user_id])
}

// -- Insight Unlocks -----------------------------------------------------------
model insight_unlock {
  id          Int      @id @default(autoincrement())
  user_id     Int
  insight_key String
  unlocked_at DateTime @default(now())
  viewed      Boolean  @default(false)
  interacted  Boolean  @default(false)
  users       users?   @relation(fields: [usersId], references: [id])
  usersId     Int?

  @@map("insight_unlocks")
  @@unique([user_id, insight_key])
  @@index([user_id])
}

// -- Partnerships (Tandem) ------------------------------------------------------
model partnership {
  id                        Int       @id @default(autoincrement())
  inviter_id                Int
  invitee_id                Int?
  status                    String    @default("pending") // 'pending'|'active'|'dissolved'
  invite_token              String    @unique
  tandem_trial_activated_at DateTime?
  dissolved_at              DateTime?
  created_at                DateTime  @default(now())

  @@map("partnerships")
  @@index([inviter_id])
  @@index([invitee_id])
}

model partner_concern {
  id          Int       @id @default(autoincrement())
  sender_id   Int
  receiver_id Int
  topic_area  String? // coaching context only -- concern_text NEVER shown to receiver
  created_at  DateTime  @default(now())
  expires_at  DateTime? // auto-expire 7 days

  @@map("partner_concerns")
  @@index([receiver_id])
}

// -- iOS Waitlist --------------------------------------------------------------
model ios_waitlist {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  created_at DateTime @default(now())
  users      users?   @relation(fields: [usersId], references: [id])
  usersId    Int?
}

model lead_magnet_email {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  magnet_type String? // 'adhd-science-cheatsheet'|'daily-three-template'
  created_at  DateTime @default(now())
  users       users?   @relation(fields: [usersId], references: [id])
  usersId     Int?

  @@map("lead_magnet_emails")
}
